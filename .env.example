WATCH_PASSWORD=change-me
# Optional separate machine token for automation like the Telegram loop.
WATCH_API_KEY=
# Optional separate signing secret for browser sessions.
WATCH_SESSION_SECRET=
# Optional demo mode for OSS onboarding without a live OpenClaw install.
WATCH_DEMO_MODE=
# Optional path and binary overrides for non-standard self-host setups.
WATCH_OPENCLAW_DIR=
WATCH_OPENCLAW_BIN=
WATCH_PM2_BIN=
WATCH_PM2_HOME=
WATCH_ORCHESTRATION_FILE=
WATCH_UPDATE_RESULT_PATH=
WATCH_SNAPMOLT_PROCESS=snapmolt
WATCH_ECHOES_PROCESS=echoes-backend
WATCH_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Optional. If omitted, the watcher will use the most recent chat that messaged the bot.
WATCH_TELEGRAM_CHAT_ID=
WATCH_URL=http://127.0.0.1:3012
WATCH_TELEGRAM_INTERVAL_MS=60000

# AXIOM Office (51-agent showcase floor at /axiom).
# REQUIRED: password for the /axiom admin zone (office + tasks).
# Login is fully disabled (returns 500) until this is set. Choose a strong value;
# the AXIOM zone exposes filesystem write access to the project dir to anyone who
# logs in.
WATCH_AXIOM_PASSWORD=change-me-please
# Optional separate signing secret for admin browser sessions (defaults to the password).
WATCH_AXIOM_SESSION_SECRET=
# Project root where agents do their work — they get workspace-write here.
# Project root where AXIOM agents do their work — workspace-write here.
WATCH_AXIOM_PROJECT_DIR=/opt/axiom
# Where the per-agent transcript JSONL, session UUIDs, and live state files live.
WATCH_AXIOM_MAILBOX_DIR=/var/lib/watcher/axiom-mailbox
# Per-agent CLI timeout in ms. Default 600000 (10 minutes).
WATCH_AXIOM_CLAUDE_TIMEOUT_MS=600000
# Filesystem sandbox via bubblewrap: when on (default), claude spawns can only
# write to AXIOM_PROJECT_DIR + AXIOM_MAILBOX_DIR + /root/.claude + tmpfs /tmp.
# Sensitive paths (/root/.ssh, /etc/ssh, .env files, /home) are masked.
# Codex has its own kernel-level workspace-write sandbox (--full-auto) and is
# always restricted regardless of this flag. Set to 0 to disable bwrap if
# bubblewrap isn't installed or you trust the agents.
WATCH_AXIOM_SANDBOX=1
WATCH_AXIOM_BWRAP_BIN=/usr/bin/bwrap

# Resource limits via systemd-run cgroup (when on, default): caps each agent spawn
# at 200% CPU, 4GB RAM, 256 tasks; blocks egress to RFC1918 + cloud-metadata IPs
# at the kernel level via BPF. Set to 0 to disable if systemd isn't available.
WATCH_AXIOM_RESOURCE_LIMITS=1

# Per-session rate limit (calls per hour, per agent). Default 60.
WATCH_AXIOM_MAX_CALLS_PER_HOUR=60
# Per-session daily cost cap in USD. Refuses calls once spent. Default 25.
WATCH_AXIOM_MAX_DAILY_USD=25
# Soft disk cap on /opt/axiom in GB (refuses spawns if filesystem nearly full). Default 50.
WATCH_AXIOM_PROJECT_SIZE_CAP_GB=50
# Codex models for CEO and managers (subscription-backed). gpt-5.5 default.
WATCH_AXIOM_CEO_MODEL=gpt-5.5
WATCH_AXIOM_MANAGER_MODEL=gpt-5.5
# Department names — exactly 10, comma-separated, front row first then back row.
# Override to fit your org. NEXT_PUBLIC_ so it's available client-side too.
NEXT_PUBLIC_AXIOM_DEPARTMENTS=Platform,Frontend,Backend,Data,Infra,Security,ML,Mobile,Growth,Research
